{
  "contract_version": "2026-03-12",
  "object": "contract",
  "name": "llm-price-api",
  "default_output_format": "json",
  "deployment_modes": [
    "local_cli",
    "local_http_api",
    "static_github_pages"
  ],
  "response_envelope": {
    "required_fields": [
      "contract_version",
      "object",
      "data"
    ],
    "optional_fields": [
      "meta",
      "error"
    ]
  },
  "catalog_contract": {
    "required_model_fields": [
      "id",
      "provider",
      "model",
      "status",
      "pricing_mode",
      "released_at",
      "release_source_url",
      "last_verified_at",
      "source_url",
      "pricing.input_usd_per_1m_tokens",
      "pricing.output_usd_per_1m_tokens"
    ],
    "recommended_model_fields": [
      "family",
      "description",
      "modalities",
      "context_window_tokens",
      "max_output_tokens",
      "tags",
      "comparison_pricing_basis",
      "release_source_note",
      "pricing_tiers",
      "pricing.batch_input_usd_per_1m_tokens",
      "pricing.batch_output_usd_per_1m_tokens",
      "source_url",
      "source_note",
      "availability_note"
    ]
  },
  "http_endpoints": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Basic server health check."
    },
    {
      "method": "GET",
      "path": "/v1/catalog",
      "description": "Return the raw pricing catalog."
    },
    {
      "method": "GET",
      "path": "/v1/contract",
      "description": "Return the machine-readable API contract."
    },
    {
      "method": "GET",
      "path": "/v1/models",
      "description": "List models newest release first by default, or fetch one model with ?id=<model_id>."
    },
    {
      "method": "POST",
      "path": "/v1/compare",
      "description": "Estimate workload cost for specific models or a filtered subset."
    },
    {
      "method": "POST",
      "path": "/v1/analyze",
      "description": "Return ranked analysis, cheapest model, and budget-fit models."
    }
  ],
  "static_documents": [
    {
      "path": "data/pricing.catalog.json",
      "description": "Raw pricing catalog for static hosting."
    },
    {
      "path": "contracts/llm-price-api.contract.json",
      "description": "Raw contract document for static hosting."
    },
    {
      "path": "api/index.json",
      "description": "Index of generated static JSON views."
    },
    {
      "path": "api/snapshots/index.json",
      "description": "Index of historical pricing catalog snapshots."
    },
    {
      "path": "api/views/by-release-date.json",
      "description": "Precomputed model ordering by release date descending."
    },
    {
      "path": "api/views/by-input-price.json",
      "description": "Precomputed model ordering by input token price."
    },
    {
      "path": "api/views/by-output-price.json",
      "description": "Precomputed model ordering by output token price."
    },
    {
      "path": "api/views/workloads/balanced.json",
      "description": "Precomputed workload comparison for a balanced preset."
    },
    {
      "path": "api/views/status/active.json",
      "description": "Precomputed model list for active models."
    },
    {
      "path": "api/views/pricing-modes/text_tokens.json",
      "description": "Precomputed model list for a pricing mode."
    }
  ],
  "cli_commands": [
    {
      "command": "llm-pricing list --format json",
      "description": "List models in JSON, newest release first by default."
    },
    {
      "command": "llm-pricing show openai/gpt-5-mini",
      "description": "Return one model document."
    },
    {
      "command": "llm-pricing compare --models openai/gpt-5-mini,google/gemini-2.5-flash-lite --input-tokens 1000000 --output-tokens 250000",
      "description": "Compare workload cost."
    },
    {
      "command": "llm-pricing analyze --input-tokens 1000000 --output-tokens 250000 --budget-usd 2",
      "description": "Rank the catalog for a given workload."
    },
    {
      "command": "llm-pricing serve --port 3030",
      "description": "Run the local HTTP API."
    }
  ],
  "request_shapes": {
    "compare": {
      "model_ids": [
        "openai/gpt-5-mini",
        "google/gemini-2.5-flash-lite"
      ],
      "filters": {
        "provider": "openai",
        "status": "active",
        "tag": "cost"
      },
      "workload": {
        "input_tokens": 1000000,
        "cached_input_tokens": 0,
        "output_tokens": 250000
      },
      "sort_by": "estimated_total_cost_usd"
    },
    "analyze": {
      "filters": {
        "provider": "google",
        "status": "active"
      },
      "workload": {
        "input_tokens": 1000000,
        "output_tokens": 250000
      },
      "budget_usd": 2,
      "top_k": 3
    }
  },
  "response_examples": {
    "list": {
      "contract_version": "2026-03-12",
      "object": "list",
      "data": [
        {
          "id": "openai/gpt-5-mini",
          "provider": "openai",
          "status": "active",
          "pricing_mode": "text_tokens",
          "released_at": "2025-08-07",
          "release_source_url": "https://openai.com/index/gpt-5-new-era-of-work/",
          "last_verified_at": "2026-03-12",
          "comparison_pricing_basis": "Standard text-token pricing from the official model page.",
          "pricing": {
            "input_usd_per_1m_tokens": 0.25,
            "cached_input_usd_per_1m_tokens": 0.025,
            "output_usd_per_1m_tokens": 2
          }
        }
      ],
      "meta": {
        "count": 1
      }
    },
    "compare": {
      "contract_version": "2026-03-12",
      "object": "price_comparison",
      "data": {
        "workload": {
          "input_tokens": 1000000,
          "cached_input_tokens": 0,
          "output_tokens": 250000
        },
        "comparisons": [
          {
            "model_id": "openai/gpt-5-mini",
            "released_at": "2025-08-07",
            "release_source_url": "https://openai.com/index/gpt-5-new-era-of-work/",
            "last_verified_at": "2026-03-12",
            "status": "active",
            "comparison_pricing_basis": "Standard text-token pricing from the official model page.",
            "estimated_total_cost_usd": 0.75
          }
        ]
      }
    }
  }
}
